generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  xp           Int      @default(0)
  rank         Int      @default(1000)
  tokens       Int      @default(100) // spell currency
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  player1Matches Match[]      @relation("Player1Matches")
  player2Matches Match[]      @relation("Player2Matches")
  submissions    Submission[]
  spells         Spell[]
  winnerMatches  Match[]      @relation("Winner")

  @@map("users")
}

model Problem {
  id            String     @id @default(cuid())
  title         String
  description   String
  difficulty    Difficulty
  testCases     Json       @map("test_cases")
  timeLimitMs   Int        @map("time_limit_ms")
  memoryLimitMb Int        @map("memory_limit_mb")
  tags          String[]
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  // Relations
  matches     Match[]
  submissions Submission[]

  @@map("problems")
}

model Match {
  id           String      @id @default(cuid())
  player1Id    String      @map("player1_id")
  player2Id    String      @map("player2_id")
  problemId    String      @map("problem_id")
  status       MatchStatus @default(WAITING)
  winnerId     String?     @map("winner_id")
  startedAt    DateTime?   @map("started_at")
  endedAt      DateTime?   @map("ended_at")
  currentRound Int         @default(1) @map("current_round")
  timeLimit    Int         @default(300) // 5 minutes in seconds
  player1Hp    Int         @default(100) @map("player1_hp")
  player2Hp    Int         @default(100) @map("player2_hp")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  // Relations
  player1     User          @relation("Player1Matches", fields: [player1Id], references: [id])
  player2     User          @relation("Player2Matches", fields: [player2Id], references: [id])
  problem     Problem       @relation(fields: [problemId], references: [id])
  winner      User?         @relation("Winner", fields: [winnerId], references: [id])
  submissions Submission[]
  spells      BattleSpell[]

  @@map("matches")
}

model Submission {
  id          String   @id @default(cuid())
  matchId     String   @map("match_id")
  userId      String   @map("user_id")
  problemId   String   @map("problem_id")
  code        String
  language    String
  passedTests Int      @map("passed_tests")
  totalTests  Int      @map("total_tests")
  execTimeMs  Int      @map("exec_time_ms")
  damageDealt Int      @default(0) @map("damage_dealt")
  createdAt   DateTime @default(now()) @map("created_at")

  // Relations
  match   Match   @relation(fields: [matchId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@map("submissions")
}

model Spell {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  type          SpellType
  usesRemaining Int       @map("uses_remaining")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
  @@map("spells")
}

model BattleSpell {
  id        String    @id @default(cuid())
  matchId   String    @map("match_id")
  casterId  String    @map("caster_id")
  targetId  String?   @map("target_id")
  spellType SpellType @map("spell_type")
  effect    Json? // spell effects data
  castAt    DateTime  @default(now()) @map("cast_at")

  // Relations
  match Match @relation(fields: [matchId], references: [id])

  @@map("battle_spells")
}

model PuzzleBenchmark {
  id           String   @id @default(cuid())
  puzzleId     String   @map("puzzle_id")
  language     String
  p50RuntimeMs Int      @map("p50_runtime_ms")
  sampleSize   Int      @map("sample_size")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([puzzleId, language])
  @@map("puzzle_benchmarks")
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum MatchStatus {
  WAITING
  COUNTDOWN
  ACTIVE
  JUDGING
  COMPLETED
}

enum SpellType {
  HINT
  TIME_FREEZE
  SLOW
  HEAL
  DAMAGE
  SHIELD
}
