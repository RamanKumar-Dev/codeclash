// This is Prisma's schema file
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  elo          Int      @default(1000)
  wins         Int      @default(0)
  losses       Int      @default(0)
  winStreak    Int      @default(0) @map("win_streak")
  spellsCast   Int      @default(0) @map("spells_cast")
  hp           Int      @default(500)
  maxHp        Int      @default(500) @map("max_hp")
  avatar       String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  matchesAsPlayer1 Match[]           @relation("Player1Matches")
  matchesAsPlayer2 Match[]           @relation("Player2Matches")
  matchesWon       Match[]           @relation("WinnerMatches")
  submissions      Submission[]
  battleSpells     BattleSpell[]
  battleDamage     BattleDamage[]
  achievements     UserAchievement[]

  @@map("users")
}

model Problem {
  id            String   @id @default(cuid())
  title         String
  description   String
  difficulty    String // 'easy' | 'medium' | 'hard'
  testCases     String   @default("[]") @map("test_cases")
  timeLimitMs   Int      @map("time_limit_ms")
  memoryLimitMb Int      @map("memory_limit_mb")
  p50RuntimeMs  Int      @default(1000) @map("p50_runtime_ms")
  tags          String   @default("[]")
  examples      String   @default("[]")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Relations
  matches     Match[]
  submissions Submission[]

  @@map("problems")
}

model Match {
  id           String    @id @default(cuid())
  player1Id    String    @map("player1_id")
  player2Id    String    @map("player2_id")
  problemId    String    @map("problem_id")
  status       String    @default("waiting")
  winnerId     String?   @map("winner_id")
  startedAt    DateTime? @map("started_at")
  endedAt      DateTime? @map("ended_at")
  currentRound Int       @default(1) @map("current_round")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // Relations
  player1      User           @relation("Player1Matches", fields: [player1Id], references: [id])
  player2      User           @relation("Player2Matches", fields: [player2Id], references: [id])
  winner       User?          @relation("WinnerMatches", fields: [winnerId], references: [id])
  problem      Problem        @relation(fields: [problemId], references: [id])
  submissions  Submission[]
  battleSpells BattleSpell[]
  battleDamage BattleDamage[]

  @@map("matches")
}

model Submission {
  id          String   @id @default(cuid())
  matchId     String   @map("match_id")
  userId      String   @map("user_id")
  problemId   String   @map("problem_id")
  code        String
  language    String
  passedTests Int      @map("passed_tests")
  totalTests  Int      @map("total_tests")
  execTimeMs  Int      @map("exec_time_ms")
  damageDealt Int      @map("damage_dealt")
  createdAt   DateTime @default(now()) @map("created_at")

  match   Match   @relation(fields: [matchId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  problem Problem @relation(fields: [problemId], references: [id])

  @@map("submissions")
}

model BattleSpell {
  id        String   @id @default(cuid())
  matchId   String   @map("match_id")
  casterId  String   @map("caster_id")
  targetId  String?  @map("target_id")
  spellType String   @map("spell_type")
  damage    Int?
  duration  Int?
  createdAt DateTime @default(now()) @map("created_at")

  match  Match @relation(fields: [matchId], references: [id])
  caster User  @relation(fields: [casterId], references: [id])

  @@map("battle_spells")
}

model BattleDamage {
  id         String   @id @default(cuid())
  matchId    String   @map("match_id")
  attackerId String   @map("attacker_id")
  targetId   String   @map("target_id")
  damage     Int
  damageType String   @map("damage_type")
  timestamp  DateTime @default(now()) @map("timestamp")

  match    Match @relation(fields: [matchId], references: [id])
  attacker User  @relation(fields: [attackerId], references: [id])

  @@map("battle_damage")
}

model UserAchievement {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  achievementId   String   @map("achievement_id")
  achievementName String   @map("achievement_name")
  achievementIcon String   @map("achievement_icon")
  earnedAt        DateTime @default(now()) @map("earned_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}
