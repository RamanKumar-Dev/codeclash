# Database Configuration
DATABASE_URL=postgresql://postgres:your_secure_postgres_password@localhost:5432/codeclash

# Redis Configuration
REDIS_URL=redis://localhost:6379

# JWT Configuration
JWT_SECRET=your_super_secure_jwt_secret_key_at_least_32_characters
JWT_REFRESH_SECRET=your_super_secure_jwt_refresh_secret_key_at_least_32_characters

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Server Configuration
PORT=3001
NODE_ENV=development

# Judge Service
JUDGE_SERVICE_URL=http://localhost:3002

# Clustering
CLUSTER_WORKERS=4

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
