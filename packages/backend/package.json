{
  "name": "@code-clash/backend",
  "version": "1.0.0",
  "description": "Code-Clash Arena Backend - Production Ready",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.4",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "redis": "^4.6.11",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.6.2",
    "joi": "^17.11.0",
    "zod": "^3.22.4",
    "isomorphic-dompurify": "^2.6.0",
    "mongo-sanitize": "^1.1.0",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "@sentry/node": "^7.84.0",
    "@sentry/tracing": "^7.84.0",
    "dotenv": "^16.3.1",
    "express-rate-limit": "^7.1.5",
    "node-cron": "^3.0.3",
    "@prisma/client": "^5.7.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.10.4",
    "@types/node-cron": "^3.0.11",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "prisma": "^5.7.1",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "ts-jest": "^29.1.1",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0"
  }
}
